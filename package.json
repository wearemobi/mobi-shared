{
  "name": "@wearemobi/shared",
  "version": "2.0.11",
  "description": "Universal UI & Logic Shield for M.O.B.I.™ Grand Fleet",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/mobi-shared.umd.cjs",
  "module": "./dist/mobi-shared.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/mobi-shared.js",
      "require": "./dist/mobi-shared.umd.cjs"
    },
    "./styles.css": "./dist/style.css",
    "./src/*": "./src/*"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npx @tailwindcss/cli -i src/styles.css -o dist/style.css && node -e \"const fs = require('fs'); const file = 'dist/style.css'; fs.writeFileSync(file, fs.readFileSync(file, 'utf8').replace(/\\/\\*! tailwindcss.*?\\*\\/\\n/g, ''));\" && tsc --emitDeclarationOnly",
    "prepare": "npm run build",
    "build:docs": "vite build --config vite.config.docs.ts",
    "preview": "vite preview",
    "example": "vite example --config vite.config.ts --port 5173 --strictPort",
    "example:sandbox": "vite example --config vite.config.ts --port 5173 --strictPort --mode sandbox"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wearemobi/mobi-shared.git"
  },
  "keywords": [
    "mobi",
    "shared",
    "ui",
    "auth"
  ],
  "author": "M.O.B.I.™",
  "license": "ISC",
  "devDependencies": {
    "@types/emoji-mart": "^3.0.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@wearemobi/ui": "^0.2.1",
    "class-variance-authority": "^0.7.0",
    "date-fns": "^4.4.0",
    "emoji-mart": "^5.6.0",
    "lucide-react": "^0.395.0",
    "postcss": "^8.5.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^4.2.4",
    "wouter": "^3.10.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*",
    "@rollup/rollup-linux-x64-musl": "*"
  },
  "overrides": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@emoji-mart/react": {
      "react": "^19.2.5",
      "react-dom": "^19.2.5"
    }
  }
}
