{
  "name": "@wearemobi/shared",
  "version": "1.4.5",
  "description": "Universal UI & Logic Shield for M.O.B.I.™ Grand Fleet",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/mobi-shared.umd.cjs",
  "module": "./dist/mobi-shared.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/mobi-shared.js",
      "require": "./dist/mobi-shared.umd.cjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "prepare": "npm run build",
    "build:docs": "npm run build:embed && vite build --config vite.config.docs.ts && cp dist-embed/mobi-embed.js docs-dist/ && cp dist-embed/mobi-embed.css docs-dist/ && cp example/embed.html docs-dist/ && sed 's|/src/embed-loader.tsx|/mobi-embed.js|g' docs-dist/embed.html > docs-dist/embed.tmp && mv docs-dist/embed.tmp docs-dist/embed.html",
    "build:embed": "vite build --config vite.config.embed.ts",
    "preview": "vite preview",
    "example": "vite example --config vite.config.ts --port 5173 --strictPort"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wearemobi/mobi-shared.git"
  },
  "keywords": [
    "mobi",
    "shared",
    "ui",
    "auth"
  ],
  "author": "M.O.B.I.™",
  "license": "ISC",
  "devDependencies": {
    "@types/emoji-mart": "^3.0.14",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "emoji-mart": "^5.6.0",
    "postcss": "^8.5.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*",
    "@rollup/rollup-linux-x64-musl": "*"
  },
  "overrides": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@emoji-mart/react": {
      "react": "^19.2.5",
      "react-dom": "^19.2.5"
    }
  }
}
